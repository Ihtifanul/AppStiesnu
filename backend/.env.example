# ============================================
# APLIKASI STIESNU - ENVIRONMENT CONFIGURATION
# ============================================
# JANGAN SHARE FILE INI ATAU ISI RAHASIA ANDA!
# NEVER COMMIT .env TO VERSION CONTROL!

# ============ DATABASE ============
DATABASE_URL="mysql://user:password@localhost:3306/stiesnu_db"

# ============ NEXT.JS ============
NEXT_PUBLIC_API_URL="http://localhost:3000"
NODE_ENV="development"

# ============ JWT AUTHENTICATION ============
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-in-production"
JWT_EXPIRATION="7d"

# ============ EMAIL CONFIGURATION (SMTP) ============
# Gmail: Gunakan App Password, bukan password akun utama
# Petunjuk: https://support.google.com/accounts/answer/185833
MAIL_MAILER="smtp"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USERNAME="stiesnu.bkl@gmail.com"
MAIL_PASSWORD="ithoudzzuwsujlbn"
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="stiesnu.bkl@gmail.com"
MAIL_FROM_NAME="STIESNU Bengkulu"

# ============ FILE UPLOAD ============
MAX_FILE_SIZE="5242880"
UPLOAD_DIR="public/uploads"

# ============ OTP CONFIGURATION ============
OTP_EXPIRATION_MINUTES="10"
OTP_LENGTH="6"

# ============ PASSWORD RESET ============
PASSWORD_RESET_TOKEN_EXPIRATION="30"

# ============ CORS ============
CORS_ORIGIN="http://localhost:3000,http://localhost:19000"

# ============ SECURITY ============
# Hash algoritma untuk password
BCRYPT_ROUNDS="10"

# ============ LOGGING ============
LOG_LEVEL="debug"
LOG_PATH="logs"
CORS_ORIGIN="http://localhost:8081,http://localhost:3001"
